# TMDB API credentials (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=
TMDB_API_TOKEN=

# Base URL for the movie embed/streaming server; the TMDB id and &tmdb=1 are appended
NEXT_PUBLIC_EMBED_BASE_URL=https://multiembed.mov/?video_id=

# Link back to the ANIMEX site, shown in the navbar
NEXT_PUBLIC_ANIMEX_URL=https://animex.example.com

# Public URL of this deployment, used for sitemap.xml, robots.txt, and SEO metadata
NEXT_PUBLIC_SITE_URL=https://moviex.example.com
